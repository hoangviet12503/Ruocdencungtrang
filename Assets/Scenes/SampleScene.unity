  m_GameObject: {fileID: 2146087830}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f56b76e5597ceb1429b49470bdeefd6d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MidAutumn.UI.RulesScreen
  rulesBodyText: {fileID: 1237886735}
  defaultRulesText: "TH\u1EC2 L\u1EC6 CH\u01AF\u01A0NG TR\xCCNH\n\"L\u1EAEC X\xDAC
    X\u1EAEC - PH\xC1 C\u1ED6 TR\xD4NG TR\u0102NG\"\n\n1. Th\u1EDDi gian di\u1EC5n
    ra: Ch\u01B0\u01A1ng tr\xECnh di\u1EC5n ra trong 60 ng\xE0y.\n\n2. \u0110\u1ED1i
    t\u01B0\u1EE3ng tham gia: T\u1EA5t c\u1EA3 ng\u01B0\u1EDDi d\xF9ng \u1EE9ng d\u1EE5ng
    MoMo.\n\n3. C\xE1ch th\u1EE9c tham gia: Ng\u01B0\u1EDDi d\xF9ng s\u1EED d\u1EE5ng
    L\u01B0\u1EE3t Ch\u01A1i \u0111\u1EC3 gh\xE9p c\xE1c v\u1EADt ph\u1EA9m tr\xEAn
    M\xE2m C\u1ED7 \u0110\xEAm R\u1EB1m, \u0111\u1EA1t \u0110\u1EA7u L\xE2n May M\u1EAFn
    (c\u1EA5p \u0111\u1ED9 t\u1ED1i \u0111a) \u0111\u1EC3 nh\u1EADn \u0110i\u1EC3m
    L\u1ED3ng \u0110\xE8n.\n\n4. Nh\u1EADn L\u01B0\u1EE3t Ch\u01A1i: \u0110i\u1EC3m
    danh h\xE0ng ng\xE0y, ho\xE0n th\xE0nh nhi\u1EC7m v\u1EE5 trong tab Nhi\u1EC7m
    V\u1EE5.\n\n5. \u0110\u1ED5i qu\xE0: S\u1EED d\u1EE5ng \u0110i\u1EC3m L\u1ED3ng
    \u0110\xE8n \u0111\u1EC3 \u0111\u1ED5i voucher t\u1EA1i Ti\u1EC7m Qu\xE0 Trung
    Thu.\n\n6. M\u1ECDi th\u1EAFc m\u1EAFc xin li\xEAn h\u1EC7 b\u1ED9 ph\u1EADn
    h\u1ED7 tr\u1EE3 MoMo."
